<p class="text-xl">
  <strong>Title:</strong> <%= @task.title %>
</p>

<p class="mt-4">
  <strong>Status:</strong>
  <% if @task.completed %>
    <span class="text-green-500 font-semibold">Completed ✅</span>
  <% else %>
    <span class="text-yellow-500 font-semibold">Pending ⏳</span>
  <% end %>
</p>

<%= button_to "Toggle Complete", toggle_complete_task_path(@task), method: :patch, class: "mt-4 bg-indigo-500 hover:bg-indigo-600 text-white px-4 py-2 rounded" %>
