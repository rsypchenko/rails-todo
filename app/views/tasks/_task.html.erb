<div id="<%= dom_id(task) %>" class="w-1/2 p-4 rounded-lg shadow-md bg-white hover:scale-105 transform transition-all duration-300 ease-in-out animate-fade-in" data-controller="inline-edit">
   <!-- Task Title -->
  <div data-inline-edit-target="display" class="<%= 'line-through text-gray-400' if task.completed %> text-xl font-semibold cursor-pointer" data-action="click->inline-edit#toggle">
    <%= task.title %>
  </div>


  <!-- Inline Edit Form -->
  <%= form_with(model: task, data: { inline_edit_target: "form", action: "submit->inline-edit#submit" }, class: "hidden mt-2") do |f| %>
    <%= f.text_field :title, class: "border rounded p-1", data: { inline_edit_target: "input" } %>
    <%= f.submit "Save", class: "ml-2 px-2 py-1 bg-green-500 text-white rounded hover:bg-green-600 transition-all duration-300" %>
  <% end %>

  <!-- Actions -->
  <div class="mt-3 flex items-center space-x-2">
    <%= button_to "✅", toggle_complete_task_path(task), method: :patch, class: "text-sm bg-gray-200 hover:bg-gray-300 px-2 py-1 rounded" %>
    <%= button_to '🗑️', remove_task_task_path(task) , method: :delete, class: "text-red-500 hover:underline text-sm" %>
  </div>
</div>
